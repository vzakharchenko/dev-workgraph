{
  "name": "dev-workgraph-cli",
  "version": "1.0.0",
  "description": "Reconstruct forgotten engineering work from Git history.",
  "license": "Apache-2.0",
  "author": "Vasyl Zakharchenko",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "dev-workgraph": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "start:authors": "node dist/cli.js authors '../../keycloak-radius-plugin'",
    "start:export": "node dist/cli.js export '../../keycloak-radius-plugin'",
    "start:summarize": "node dist/cli.js summarize '../../keycloak-radius-plugin'",
    "commit-group": "node dist/cli.js commit-group '../../keycloak-radius-plugin' --force",
    "report": "node dist/cli.js report '../../keycloak-radius-plugin'",
    "prepare:radius": "node dist/cli.js prepare '../../keycloak-radius-plugin'",
    "final:radius": "node dist/cli.js final '../../keycloak-radius-plugin'",
    "init:repo": "node dist/cli.js init '../../keycloak-radius-plugin' --force",
    "run:repo": "node dist/cli.js run '../../keycloak-radius-plugin' --force",
    "run:repo:notes": "node dist/cli.js run '../../Forge-Secure-Notes-for-Jira'",
    "run:industry-network": "node dist/cli.js run '/Users/vasylzakharchenko/Ignore TimeMachine/old hp/vzakharchenko/modeln/IndustryNetwork'",
    "run:validata-poc": "node dist/cli.js run '/Users/vasylzakharchenko/Ignore TimeMachine/old hp/vzakharchenko/modeln/modn-sapljo-poc'",
    "run:saas-validata": "node dist/cli.js run '/Users/vasylzakharchenko/Ignore TimeMachine/old hp/vzakharchenko/modeln/saas-validata'",
    "final:repo:notes": "node dist/cli.js final '../../Forge-Secure-Notes-for-Jira' --force",
    "run:forge-sql-orm": "node dist/cli.js run '../../forge-sql-orm'",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "inquirer": "^14.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
