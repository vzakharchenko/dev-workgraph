{
  "name": "dev-workgraph",
  "version": "1.0.6",
  "description": "Turn a Git repository into a career story you can defend — reconstruct your work from commits and your own answers into role-aware impact, CV bullets, and interview prep. Local-only via Ollama.",
  "license": "Apache-2.0",
  "author": "Vasyl Zakharchenko",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "dev-workgraph": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vzakharchenko/dev-workgraph.git",
    "directory": "dev-workgraph-cli"
  },
  "homepage": "https://github.com/vzakharchenko/dev-workgraph#readme",
  "bugs": {
    "url": "https://github.com/vzakharchenko/dev-workgraph/issues"
  },
  "keywords": [
    "git",
    "cli",
    "career",
    "cv",
    "resume",
    "performance-review",
    "interview-prep",
    "ollama",
    "llm",
    "rag",
    "developer-tools",
    "code-analysis",
    "git-history"
  ],
  "scripts": {
    "build": "tsx scripts/generate-version.ts && tsc -p tsconfig.json",
    "typecheck": "tsx scripts/generate-version.ts && tsc --noEmit -p tsconfig.json",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "format:check": "biome format src",
    "verify": "npm run lint && npm run deadcode",
    "deadcode": "npm run typecheck && npm run knip",
    "prepublishOnly": "npm run verify && npm test && npm run build",
    "start": "node dist/cli.js",
    "test": "tsx scripts/generate-version.ts && vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "knip": "knip",
    "quality": "npm run build && npm run lint:fix && npm run format && npm run deadcode && npm run test:coverage",
    "reconstruct": "npm run build && node dist/cli.js migrate . && node dist/cli.js run .",
    "reconstruct:deepen": "npm run build && node dist/cli.js deepen ."
  },
  "dependencies": {
    "commander": "^15.0.0",
    "inquirer": "^14.0.2",
    "undici": "^8.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "knip": "^6.26.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
