{
  "name": "dev-workgraph-cli",
  "version": "1.0.0",
  "description": "Reconstruct forgotten engineering work from Git history.",
  "license": "Apache-2.0",
  "author": "Vasyl Zakharchenko",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "dev-workgraph": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsx scripts/generate-version.ts && tsc -p tsconfig.json",
    "typecheck": "tsx scripts/generate-version.ts && tsc --noEmit -p tsconfig.json",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "format:check": "biome format src",
    "verify": "npm run lint && npm run typecheck && npm run knip",
    "start": "node dist/cli.js",
    "test": "tsx scripts/generate-version.ts && vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "knip": "knip"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "inquirer": "^14.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "^22.19.21",
    "knip": "^6.17.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "@vitest/coverage-v8": "^3.2.4",
    "vitest": "^3.2.4"
  }
}
