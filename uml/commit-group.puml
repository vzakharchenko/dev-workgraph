!theme plain
skinparam shadowing false

title **commit-group** — incremental re-run (extension groups, §4)

actor "Developer" as DEV

rectangle "**Existing on disk**" #E8F5E9 {
  card "groups/T1.json\n[c1,c2,c3] + model" as G1
}

rectangle "**New commits exported**" #FFF8E1 {
  card "c4, c5 (summarized)" as NC
}

