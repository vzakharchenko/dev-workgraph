@startuml prepare-record
!theme plain
skinparam shadowing false
skinparam classBackgroundColor #FAFAFA

title **PreparedRecord** — schema (§10)

class "PreparedRecord" as PR #E1F5FE {
  preparedId = report.reportId
  sourceReport — file name e.g. "1759696393.json"
  groupCount — from report
  model : PreparedModelLayer
}

class "PreparedModelLayer (M:n + D copy)" as MOD #FFF3E0 {
  **history** — single unified narrative (step 1)
  **technologies** — max 5 cleaned (step 2)
  **signalReasons** — exactly 4 strings (step 3)
  **questionsAnalyses** — up to 4 threads (step 4)
  **confidence** — re-assessed (step 4)
  --
  **changeTypes** — copied from report (D)
  technicalSignal / architectureSignal / securitySignal — copied (D)
  --
  provenance { model, generatedAt, sourceReport }
}

class "Not present (vs report)" as ABS #ECEFF1 {
  no deterministic layer
  no historySource / sourceGroups
  no hiContext / mediumContext / lowContext
  no mergeCursor
  **no answers** — Q&A in finish/
}

PR *-- MOD
PR .. ABS

note bottom of MOD
  Human answers are collected in **final** / **deepen**
  and stored on the finish archive + question files —
  **not** on the prepared record (§7).
end note

@enduml


