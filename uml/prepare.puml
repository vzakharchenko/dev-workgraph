@startuml prepare-sequence
!theme plain
skinparam shadowing false

title Sequence — **prepare**

actor "Developer" as DEV
database "project.json" as PJ
database "reports/<reportId>.json" as RPT
participant "**prepare**" as PRE
participant "LLM\nnarrativeModel\nOllama | LM Studio" as LLM
database "prepared/<reportId>.json" as OUT
database "finish/<reportId>.question.json" as FOUT

DEV -> PRE : prepare ./repo

PRE -> PJ : loadProjectContext()\n(required)
PRE -> RPT : latestReport()\nhighest reportId

PRE -> PRE : rawHistory = join history[].text (D)

PRE -> LLM : [1/4] compose unified history
LLM --> PRE : history string

alt technologies present
  PRE -> LLM : [2/4] clean technologies
  LLM --> PRE : max 5 technologies
end

PRE -> LLM : [3/4] collapse signalReasons -> 4 slots
LLM --> PRE : signalReasons[4] texts

PRE -> LLM : [4/4] reframe questions + confidence\n(+ prior finish Q&A if any)
LLM --> PRE : questionsAnalyses + lineage refs

PRE -> PRE : resolvePrepareQuestionProvenanceFromLlm (D)
PRE -> PRE : enrichQuestionCards (D)
PRE -> PRE : copy changeTypes + signals from report (D)

PRE -> OUT : write PreparedRecord\n(no questionsAnalyses)
PRE -> FOUT : createFinishQuestions\n(if question file absent)

PRE --> DEV : console preview\n(history + question cards)

@enduml
