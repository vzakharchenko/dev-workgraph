@startuml prepare-overview
!theme plain
skinparam shadowing false
skinparam ArrowColor #555555

title dev-workgraph — **prepare** (§10)\nDistill **latest report** into role-aligned prepared narrative

legend top left
  |= Tag |= Meaning |
  | **(D)** | Deterministic — no LLM |
  | **(M:n)** | **narrativeModel** (Ollama / LM Studio) |
  | **(H) init** | project.json required |
endlegend

rectangle "**Preconditions**" #FFF8E1 {
  card "**init** -> project.json\n(required)" as INIT
  card "**report** -> reports/<id>.json\n(latest / highest reportId)" as REP
}

rectangle "**Not read by prepare**" #ECEFF1 {
  card "groups/" as G #CCCCCC
  card "commits/" as C #CCCCCC
  card "evidence" as E #CCCCCC
}

rectangle "**prepare (M:n + D)**" #FFF3E0 {
  card "Multi-entry report history\n-> one unified history" as H
  card "Report questions -> 4 role-aware threads" as Q
  card "Report signalReason arrays -> 4 provenance slots" as R
  card "technologies cleaned (max 5)" as T
  card "Write finish/<reportId>.question.json" as FQ
}

rectangle "**Output**" #E8F5E9 {
  card "prepared/<reportId>.json\n(history + signals + reasons)" as OUT
  card "finish/<reportId>.question.json\n(questionsAnalyses + cards)" as FOUT
  card "Console preview:\nhistory + 4 question cards" as PREV
}

INIT --> H
REP --> H
REP --> Q
REP --> R
REP --> T
H --> OUT
R --> OUT
T --> OUT
Q --> FQ
FQ --> FOUT
OUT --> PREV
FOUT --> PREV

G .. H : not loaded
C .. H
E .. H

note bottom of REP
  Takes **only the final report** in the chain —
  not intermediate report files, not groups directly.
  Cumulative work is already inside that report.
end note

note bottom of OUT
  **Idempotent per report:** skip if prepared/<reportId>.json
  exists. Narrative + signals for **final**.
  **No questionsAnalyses** (schema ≥1.0.6).
end note

note bottom of FOUT
  **finish/<reportId>.question.json** written at prepare
  (if absent). Canonical questionsAnalyses + cards.
end note

@enduml


@startuml prepare-command
!theme plain
skinparam shadowing false
skinparam ActivityBorderColor #888888
skinparam NoteBackgroundColor #FFF3E0

title **prepare** — Full command flow

start

:Require **project.json** (init);\nLoad latest **reports/<reportId>.json**;

if (No report?) then (yes)
  #Pink:Run **report** first;
  stop
else (no)
endif

if (prepared/<reportId>.json exists?) then (yes)
  :Skip (idempotent);
  stop
else (no)
endif

:Pick **narrativeModel**\n(Ollama / LM Studio);

:Build project context block from init;

partition "**Step 0 (D)** — rawHistory" {
  :Join report.history[].text\nnewline-separated;\n(not stored as final output);
}

partition "**[1/4] Compose history (M:n)**" {
  :Input: rawHistory + report signals + changeTypes\n+ project context;
  :Output: **one unified history** string;\nrole-aligned flowing prose;
}

partition "**[2/4] Clean technologies (M:n)**" {
  if (report.model.technologies non-empty?) then (yes)
    :Dedupe, collapse class hierarchy;\ncap at **5** most significant;
  else (no)
    :Skip;
  endif
}

partition "**[3/4] Collapse reasons (M:n)**" {
  :Input: report signalReasons arrays\n+ composed history;
  :Output: **exactly 4** flat signalReasons strings;\nmerge near-dups, drop upkeep noise;
}

partition "**[4/5] Reframe questions (M:n)**" {
  :Input: composed history + 4 reason slots\n+ report.questionsAnalyses\n+ **prior finish Q&A**\n+ project context;
  :Output: **up to 4** threads + lineage refs\n(derivedFromThreadIds / SignalRefs / Slots);\nre-assess **confidence**;
}

partition "**[5/5] Provenance + cards + persist (D + M:n)**" {
  :**resolvePrepareQuestionProvenanceFromLlm (D):**\nlineageKind, sourceGroupIds;
  :**enrichQuestionCards (D):**\nevidence from observation[] + commits;\nwhyAsked from missingPiece;
  :**polishEvidenceExcerptsWithLlm (M:n):**\n3–4 bullets per card (batched, optional);
  :**createFinishQuestions (D):**\nwrite finish/<reportId>.question.json\n(if not exists);
}

partition "**Copy from report (D)**" {
  :changeTypes, *Signal levels\nunchanged from report.model;
}

:Write prepared/<reportId>.json\n(history + 4 signalReason slots — no analyses);

:Console preview: unified history,\ntechnologies, numbered question cards\n+ Evidence / Why asked;

#LightGreen:Ready for **final**;

stop

@enduml


@startuml prepare-report-link
!theme plain
skinparam shadowing false

title **prepare** <- **report** — what is taken from the final report

rectangle "**Latest report only**" #FFF8E1 {
  card "reports/<reportId>.json\n(highest reportId)" as R
}

rectangle "**Used from report**" #E3F2FD {
  component "history[] — all entry texts\n-> rawHistory (D concat)" as RH
  component "model.technical/architecture/security Signal\n(copied D)" as SIG
  component "model.changeTypes (copied D)" as CT
  component "model.signalReasons provenance arrays\n-> 4 slots (M:n)" as SR
  component "model.questionsAnalyses\n-> reframed to 4 (M:n)" as RQ
  component "model.technologies\n-> cleaned max 5 (M:n)" as RT
  component "model.confidence\n(re-assessed in step 4)" as CONF
  component "groupCount, reportId" as META
}

rectangle "**Dropped / not carried forward**" #ECEFF1 {
  card "report.deterministic" as D #CCCCCC
  card "historySource graph" as HS #CCCCCC
  card "hi/medium/lowContext tiers" as CTX #CCCCCC
  card "mergeCursor, mergedFrom" as MC #CCCCCC
  card "sourceGroups list" as SG #CCCCCC
}

rectangle "**Transformation**" #FFF3E0 {
  card "history[] (many entries)\n-> **one** history string" as ONE
  card "questions (many)\n-> **four** for final Q&A" as FOUR
}

R --> RH
R --> SIG
R --> CT
R --> SR
R --> RQ
R --> RT
R --> META
RH --> ONE
RQ --> FOUR

note bottom of ONE
  Report history stays bounded (mergeCursor compact).
  Prepare **rewrites** all entries into one coherent
  role-aligned narrative — not a mechanical join.
end note

note bottom of D
  Prepared record has **no deterministic layer** —
  interpretation for human review only.
  Provenance: sourceReport file name (no commit hashes).
end note

@enduml


