@startuml report-sequence
!theme plain
skinparam shadowing false

title Sequence — fold **left to right** with resume

actor "Developer" as DEV
database "groups/*.json" as GRP
database "reports/*.json" as RPT
participant "**report**" as REP
participant "Ollama\nreportModel" as LLM

DEV -> REP : report ./repo

REP -> GRP : load groups (model != null)\noldest first
REP -> RPT : resume longest prefix\n(unless --force)

loop for each group G_k left to right
  alt k = 1
    REP -> REP : init(G1) — seed report
  else k > 1
    REP -> RPT : **read report_{k-1}.json**\n(input 1 — prev report)
    REP -> GRP : **read G_k.json**\n(input 2 — next group only)
    note over RPT, GRP
      merge uses **two files**:
      last report snapshot + one new group
    end note
    REP -> LLM : [1] routine gate (on group)
    alt substantive
      REP -> LLM : [2] merge model layers
      REP -> LLM : [3] add history if new
      opt history > 12
        REP -> LLM : [4] compact pair @ mergeCursor
        REP -> REP : advance mergeCursor
      end
    end
    REP -> REP : report_k = merge(report_{k-1}, G_k)
  end
  REP -> RPT : write reports/<ts>.json\n(+ mergedFrom links)
end

REP --> DEV : final report path

@enduml


@startuml report-merge-internals
!theme plain
skinparam shadowing false
skinparam NoteBackgroundColor #FFFDE7

title **Inside merge** — what happens to model + history (substantive path)

rectangle "**Inputs**" as IN {
  card "prev report\n(model + history + mergeCursor\n+ historySource graph)" as PREV #FFF8E1
  card "next group G_k\n(model + history)" as GRP #E3F2FD
}

rectangle "**Deterministic (D) — code**" as DET #E8F5E9 {
  card "Union deterministic evidence" as D1
  card "sourceGroups += G_k\n(cumulative group list)" as D2
  card "**Signals level:**\ntech/arch/sec = max(prev, group)" as D3
  card "mergedFrom ->\nprev report file + G_k" as D4
}

rectangle "**[2/4] Model merge (M:r)**" as MMOD #FFF3E0 {
  card "**signalReasons** arrays:\nmerge prev + group reasons,\ncollapse near-duplicates" as SR
  card "**questions:**\nrecompute for COMBINED work;\ndrop duplicates;\nkeep most valuable for role" as Q
  card "**hiContext / mediumContext / lowContext:**\nmerge bullets from both sides;\ncollapse duplicates;\nre-rank importance **downward only**;\ncap <= 12 per tier (role-first)" as CTX
  card "changeTypes union;\nconfidence re-assessed" as CT
}

rectangle "**[3/4] History add-if-new (M:r + D graph)**" as HADD #E1F5FE {
  card "If group adds new substance:\nappend history[n].text" as HT
  card "**historySource[n] = [G_k]**\nlink entry -> group file" as HS
}

rectangle "**[4/4] Rolling history compact (M:r + D)**" as HCOMP #FCE4EC {
  card "if len(history) > 12:\npair @ **mergeCursor**" as P
  card "LLM: merge 2 texts -> 1" as MT
  card "**Union historySource[i] + [i+1]**\ngraph keeps ALL group files\nthat fed the merged story" as MU
  card "advance cursor (+1, wrap)\n**merge by circle**, not always oldest" as CUR
}

PREV --> DET
GRP --> DET
PREV --> MMOD
GRP --> MMOD
PREV --> HADD
GRP --> HADD
HADD --> HCOMP

note bottom of MU
  **Provenance graph:** history[i] <-> historySource[i]
  Each row lists **group file names** (not commit hashes).
  Index i always pairs: story text + which groups sourced it.
  On compact, group links **accumulate** (union), not lost.
end note

note bottom of Q
  Not a simple concat of group questions —
  LLM **re-evaluates** for the growing body of work.
  Same for context tiers: merge + demote-only ranking.
end note

@enduml


