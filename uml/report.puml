!theme plain
skinparam shadowing false
skinparam NoteBackgroundColor #FFFDE7

title Rolling **mergeCursor** — merge history **by circle** + union group links

rectangle "Before compact (len=13, cap=12, cursor=2)" {
  card "h[0]" as H0
  card "h[1]" as H1
  card "h[2]" as H2 #FFE082
  card "h[3]" as H3 #FFE082
  card "..." as HX
  card "h[12] newest" as HN
}

rectangle "historySource (parallel)" #E3F2FD {
  card "s[0]->G1" as S0
  card "s[1]->G2" as S1
  card "s[2]->G3,G4" as S2 #FFE082
  card "s[3]->G5" as S3 #FFE082
  card "s[12]->G13" as SN
}

H2 .. S2
H3 .. S3

rectangle "After compact @cursor=2" {
  card "h[0]" as H0b
  card "h[1]" as H1b
  card "**h[2]' merged**" as H2b #C8E6C9
  card "..." as HXb
  card "h[11] newest unchanged" as HNb
}

rectangle "historySource after" #E3F2FD {
  card "s[0]->G1" as S0b
  card "s[1]->G2" as S1b
  card "**s[2]' -> G3,G4,G5**" as S2b #C8E6C9
  card "s[11]->G13" as SNb
}

