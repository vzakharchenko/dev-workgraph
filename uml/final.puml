@startuml final-finish-record
!theme plain
skinparam shadowing false
skinparam classBackgroundColor #FAFAFA

title **Step 4** — FinishRecord archive

class "FinishRecord" as FR #E1F5FE {
  finishId = prepared.preparedId
  sourcePrepared — prepared file name
  sourceReport — report file name (traceability)
  sourceQuestions — finishId: v1, v2, ...
  project — repo basename
  role
  technologies
  history — refined impactHistory
  narrative — 4 Role Narrative bullets
  cvBullets — 4 CV lines
  answers — questionId + answer (cumulative)
  outputMarkdown — finish/<id>.md
  version — finish-chain cursor
  provenance { model, generatedAt }
}

class "FinishQuestionsRecord" as FQR #FCE4EC {
  sourceFinal — paired finish json file
  sourceReport — traceability
  questions — id + question\nid = Unix-ms timestamp
}

class "On disk" as DISK {
  finish/<id>.md — copy of markdown
  finish/<id>.json — FinishRecord
  finish/<id>.question.json — v1 questions
  finish/<id>.question.vN.json — deepen / extension
}

class "Also on disk" as CWD {
  cwd/RECONSTRUCTION.<project>.md — primary deliverable
}

FR *-- DISK
FR o-- FQR : sourceQuestions labels\n-> question files on disk
FR .. CWD : same content

note bottom of FR
  **answers[]** references question ids only.
  **sourceQuestions** lists rounds (v1, v2, …) — not file paths.
  Links back through prepared -> report by **file name**.
  Extension / deepen: append vN+1 (never overwrite v1..vN).
end note

@enduml


@startuml final-sequence
!theme plain
skinparam shadowing false

title Sequence — **final**

actor "Developer" as DEV
database "prepared/<id>.json" as PREP
database "project.json" as PJ
participant "**final**" as FIN
participant "LLM\nnarrativeModel\nOllama | LM Studio" as LLM
database "cwd/RECONSTRUCTION.*.md" as MD
database "finish/*.question.json" as QFILE
database "finish/" as ARCH

DEV -> FIN : final ./repo [--answers-file]

FIN -> PJ : loadProjectContext (required)
FIN -> PREP : latestPrepared()

FIN -> ARCH : latestFinish() (if any)

alt extension mode (new prepared + prior finish)
  FIN -> ARCH : resolve prior Q&A\n(sourceQuestions + question files)
  FIN -> DEV : new questions only (up to 4)
  DEV --> FIN : new answers
  FIN -> QFILE : write <id>.question.vN.json
  FIN -> FIN : allQa = prior + new
else no saved answers
  FIN -> DEV : up to 4 interactive questions
  DEV --> FIN : answers
  FIN -> QFILE : write <id>.question.json
else reuse or answers-file
  FIN -> ARCH : load existing answers
  FIN -> QFILE : load existing question file
end

FIN -> ARCH : persist answers[] +\nsourceQuestions on finish record

FIN -> LLM : [2a] refine IMPACT narrative\n(history + Q&A + project context)
LLM --> FIN : impactHistory

FIN -> LLM : [2b] Role Narrative\n(impactHistory + signalReasons + Q&A)
LLM --> FIN : narrative x4

FIN -> FIN : assemble markdown (D)
FIN -> MD : write RECONSTRUCTION.<project>.md
FIN -> ARCH : finish/<id>.md + .json\n+ .question.json\nor <id>.vN + .question.vN

FIN --> DEV : path to deliverable

@enduml



