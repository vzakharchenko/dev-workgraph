@startuml final-command
!theme plain
skinparam shadowing false
skinparam ActivityBorderColor #888888
skinparam NoteBackgroundColor #FCE4EC

title **final** — Full command flow

start

:Require **project.json** + latest **prepared/<reportId>.json**;

if (No prepared?) then (yes)
  #Pink:Run **prepare** first;
  stop
else (no)
endif

if (Prior finish with answers\nAND new prepared file?) then (yes — **extension mode**)
  partition "**Extension — Step 1 (H)**" {
    :Load cumulative Q&A from **latestFinish()**\nresolve via **sourceQuestions** + question files;
    :Ask **new** questions only\n(dedupe by normalized text, up to 4);
    :Write **<id>.question.vN.json**\n{ id, question } x up to 4;
    :Merge prior + new -> **allQa**;
    :Persist **answers[]** + extend **sourceQuestions**\non new finish archive vN+1;
  }
else (first run / same prepared)
  partition "**Step 1 — Collect answers (H, no LLM)**" {
    if (--answers-file?) then (yes)
      :Load answers from JSON file;
    else if (saved answers on finish\nfor this round?) then (yes)
      :Reuse answers from finish archive\n+ existing question file;
    else (no)
      :Interactive editor:\nup to 4 questions\n(multi-line allowed);
    endif
    :Write **<id>.question.json**\n{ id, question } x up to 4;
    :Persist **answers[]** (`questionId` refs)\n+ **sourceQuestions: { id: ["v1"] }**\non finish/<id>.json;
  }
endif

:Pick **narrativeModel**\n(Ollama / LM Studio);

partition "**Step 2a — Refine Your IMPACT (M:n)**" {
  :Input: prepared.model.history\n+ prior finish.history (extension)\n+ **all** Q&A + project context;
  :Weave answers into narrative;\nANSWER_CORRECTION_RULE:\nanswers override over-strong Git claims;
  :Output: **impactHistory**;\nfallback = prepared history on failure;
  note right
    Prepared history NOT modified on disk
  end note
}

partition "**Step 2b — Role Narrative (M:n)**" {
  :Input: **impactHistory** (from 2a)\n+ 4 signalReasons + Q&A + project context;
  :Output: **exactly 4** impact bullets;\nclaim-safe engineer-to-engineer tone;
}

partition "**Step 3 — Write markdown (D)**" {
  :Assemble RECONSTRUCTION.<project>.md\n-> **process.cwd()** (not repo path);
  note right
    ## PROJECT DESCRIPTION (from profile)
    ## Your IMPACT as {ROLE}
    ## Technologies
    ## Impact bullet points
    ## Possible questions (Q&A)
  end note
}

partition "**Step 4 — Archive (D)**" {
  if (extension mode?) then (yes)
    :Append finish/<id>.vN.{md,json}\n+ <id>.question.vN.json\nsourcePreviousFinish, version N+1;
    :Extend **sourceQuestions** e.g. ["v1","v2"];
    :Write RECONSTRUCTION.<project>.vN.md;
  else (no)
    :Copy markdown -> finish/<id>.md;
    :Write FinishRecord -> finish/<id>.json\n+ <id>.question.json (version 1);
  endif
}

#LightGreen:MVP deliverable complete;

stop

@enduml


